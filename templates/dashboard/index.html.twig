{% extends 'base.html.twig' %}

{% block title %}Dashboard — MC Add-on Manager{% endblock %}

{% block body %}

    <div class="d-flex justify-content-end mb-3">
        <span class="badge bg-light text-dark border d-inline-flex align-items-center gap-1" title="Live: WebSocket status">
            <span data-ws-status-dot style="width:9px;height:9px;border-radius:50%;background:#6c757d;display:inline-block;flex-shrink:0"></span>
            <span>Live</span>
        </span>
    </div>

    {# Host stats card (always show) #}
    <div class="card shadow-sm mb-4 bg-dark text-white" id="hostStatsCard">
        <div class="card-body">
            <strong class="d-block mb-2">🖥️ Host Resources</strong>

            {# Memory #}
            <div class="mb-3">
                <div class="d-flex justify-content-between small mb-1">
                    <span>Memory</span>
                    <span id="hostMemText">–</span>
                </div>
                <div class="progress" style="height:8px">
                    <div class="progress-bar bg-info" id="hostMemBar" role="progressbar" style="width:0%"></div>
                </div>
            </div>

            {# Disk #}
            <div class="mb-0">
                <div class="d-flex justify-content-between small mb-1">
                    <span>Disk</span>
                    <span id="hostDiskText">–</span>
                </div>
                <div class="progress" style="height:8px">
                    <div class="progress-bar bg-success" id="hostDiskBar" role="progressbar" style="width:0%"></div>
                </div>
                <small id="hostDiskWarning" class="text-warning d-none mt-1">
                    {{ '⚠️ Less than %gb% GB free — server creation disabled'|trans({'%gb%': '<span id="hostDiskMinFree"></span>'})|raw }}
                </small>
            </div>
        </div>
    </div>

    {% if serverData is empty %}
        <div class="alert alert-warning">
            No servers found. Make sure your server folders (for example <code>server1</code>, <code>server2</code>) exist under <code>/mc-data/</code>.
        </div>
    {% endif %}

    {# New Server button #}
    <div class="mb-4">
        <button class="btn btn-success"
                id="newServerBtn"
                data-bs-toggle="modal"
                data-bs-target="#newServerModal"
                data-title-enabled="{{ 'Create new server'|trans }}"
                data-title-disabled-template="{{ 'Less than %gb% GB free — cannot create new server'|trans({'%gb%': '__GB__'}) }}">
            {{ '➕ New Server'|trans }}
        </button>
    </div>

    {# New Server modal #}
    <div class="modal fade" id="newServerModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ '➕ Create New Server'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="{{ path('server_create') }}">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="displayName" class="form-label">{{ 'Display Name'|trans }} <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="displayName" name="display_name" placeholder="{{ 'e.g. Creative World'|trans }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="seed" class="form-label">{{ 'World Seed (optional)'|trans }}</label>
                            <input type="text" class="form-control" id="seed" name="seed" placeholder="{{ 'Leave empty for random'|trans }}">
                        </div>
                        <div class="mb-3">
                            <label for="memoryProfile" class="form-label">{{ 'Memory Profile'|trans }}</label>
                            <select class="form-select" id="memoryProfile" name="memory_profile">
                                <option value="low">{{ 'Low (1GB)'|trans }}</option>
                                <option value="medium" selected>{{ 'Medium (2GB)'|trans }}</option>
                                <option value="high">{{ 'High (4GB)'|trans }}</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-success" id="createServerBtn">{{ 'Create Server'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {% if serverData is not empty %}
        {% for data in serverData %}
            {% set server = data.server %}
            {% set serverDomId = server.name|replace({'-': '_'}) %}
            {% set profile = server.memoryProfile|default('medium') %}
            {% set profileBadgeClass = profile == 'high' ? 'bg-danger' : (profile == 'low' ? 'bg-secondary' : 'bg-info text-dark') %}
            <div class="card shadow-sm mb-4"
                data-server="{{ server.name }}"
                data-last-started-at="{{ server.startedAt ?? '' }}">

                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="h5 mb-0">🖥️ {{ server.name }}</h2>
                        {% if server.containerName %}
                            <span class="badge bg-secondary">🐳 {{ server.containerName }}</span>
                        {% endif %}
                        {% set inferredPort = null %}
                        {% if server.name matches '/^server\\d+$/' %}
                            {% set inferredPort = 19131 + ((server.name|replace({'server': ''})) + 0) %}
                        {% endif %}
                        {% set displayPort = server.port ?? inferredPort %}
                        {% if displayPort %}
                            <span class="badge bg-secondary">:{{ displayPort }}</span>
                        {% endif %}
                        {% set awaitingStartup = (not server.isRunning) and (server.containerStatus in ['restarting', 'starting']) %}
                        <span class="badge {{ server.isRunning ? 'bg-success' : (awaitingStartup ? 'bg-warning text-dark' : 'bg-danger') }} server-status-badge">
                            {{ server.isRunning ? '● Running' : (awaitingStartup ? '⏳ Awaiting startup' : '● Stopped') }}
                        </span>
                        <button type="button"
                                class="badge border-0 {{ profileBadgeClass }} memory-profile-badge"
                                data-profile="{{ profile }}"
                                data-bs-toggle="modal"
                                data-bs-target="#memoryProfileModal{{ serverDomId }}"
                                title="{{ 'Change memory profile'|trans }}"
                                style="cursor:pointer">
                            🧠 {{ profile|upper }}
                        </button>
                        <span class="badge bg-dark stat-uptime" title="Uptime" style="{{ server.isRunning ? '' : 'display:none' }}">UP –</span>
                        <span class="badge bg-dark stat-cpu" title="CPU usage" style="{{ server.isRunning ? '' : 'display:none' }}">CPU –</span>
                        <span class="badge bg-dark stat-mem" title="Memory usage" style="{{ server.isRunning ? '' : 'display:none' }}">MEM –</span>
                        <span class="badge bg-primary stat-players" title="Online players" style="{{ server.isRunning ? '' : 'display:none' }}">👥 –</span>
                        <span class="badge bg-success">{{ data.enabledCount }} enabled</span>
                        <span class="badge bg-secondary">{{ data.disabledCount }} disabled</span>
                    </div>
                    <div class="d-flex gap-2">
                        <form method="post" action="{{ path('server_restart', {serverName: server.name}) }}" class="server-start-form">
                            <button type="submit"
                                    class="btn btn-sm server-start-btn {{ server.isRunning ? 'btn-warning' : 'btn-success' }}"
                                    data-label-start="{{ '▶ Start server'|trans }}"
                                    data-label-restart="{{ '🔄 Restart server'|trans }}">
                                {{ server.isRunning ? '🔄 Restart server'|trans : '▶ Start server'|trans }}
                            </button>
                        </form>

                        <form method="post" action="{{ path('server_stop', {serverName: server.name}) }}"
                              class="server-stop-form"
                              style="{{ server.isRunning ? '' : 'display:none' }}"
                              onsubmit="return confirm('{{ 'Stop %server%?'|trans({'%server%': server.containerName ?? server.name}) }}')">
                            <button type="submit" class="btn btn-sm btn-danger">{{ '⏹ Stop'|trans }}</button>
                        </form>
                        <button type="button"
                                class="btn btn-sm btn-outline-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteServerModal{{ server.name }}">
                            {{ '🗑 Delete server'|trans }}
                        </button>
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#installModal{{ server.name }}">⬆️ Install add-on</button>
                    </div>
                </div>

                <div class="modal fade" id="deleteServerModal{{ server.name }}" tabindex="-1">
                    <div class="modal-dialog modal-sm">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">{{ 'Delete server'|trans }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p class="mb-0">{{ 'Are you sure you want to delete server "%server%"? This will permanently remove its container and data folder.'|trans({'%server%': server.name}) }}</p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                                <form method="post" action="{{ path('server_delete', {serverName: server.name}) }}">
                                    <button type="submit" class="btn btn-danger btn-sm">{{ 'Delete permanently'|trans }}</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="memoryProfileModal{{ serverDomId }}" tabindex="-1">
                    <div class="modal-dialog modal-sm">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">{{ 'Change memory profile'|trans }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" action="{{ path('server_profile_update', {serverName: server.name}) }}">
                                <div class="modal-body">
                                    <p class="mb-2 small text-muted">
                                        {{ 'Changing profile recreates the Docker container for this server.'|trans }}
                                    </p>
                                    <label for="memoryProfileEdit{{ serverDomId }}" class="form-label">{{ 'Memory profile'|trans }}</label>
                                    <select id="memoryProfileEdit{{ serverDomId }}" name="memory_profile" class="form-select memory-profile-select">
                                        <option value="low" {{ profile == 'low' ? 'selected' : '' }}>{{ 'Low (1GB)'|trans }}</option>
                                        <option value="medium" {{ profile == 'medium' ? 'selected' : '' }}>{{ 'Medium (2GB)'|trans }}</option>
                                        <option value="high" {{ profile == 'high' ? 'selected' : '' }}>{{ 'High (4GB)'|trans }}</option>
                                    </select>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                                    <button type="submit" class="btn btn-primary btn-sm">{{ 'Apply profile'|trans }}</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                {# Install add-on modal #}
                <div class="modal fade" id="installModal{{ server.name }}" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">⬆️ Install add-on on {{ server.name }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <form method="post" action="{{ path('addon_install', {serverName: server.name}) }}" enctype="multipart/form-data">
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label for="addonFile{{ server.name }}" class="form-label">Select <code>.mcaddon</code> or <code>.mcpack</code> file</label>
                                        <input type="file" class="form-control" id="addonFile{{ server.name }}" name="addon_file" accept=".mcaddon,.mcpack" required>
                                    </div>
                                    <p class="text-muted small mb-0">The add-on will be extracted and placed in the correct packs folder automatically.</p>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Install</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <div class="card-body p-0">
                    {% if data.packs is empty %}
                        <p class="text-muted p-3 mb-0">No add-ons installed yet.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover table-striped mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Version</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in data.packs %}
                                        {% set pack = item.pack %}
                                        <tr class="{{ not item.depsSatisfied ? 'table-warning' : '' }}"
                                            data-uuid="{{ pack.manifest.uuid }}">
                                            <td>
                                                {{ pack.manifest.name }}
                                                {% if not item.depsSatisfied %}
                                                    {% set depContent %}
                                                        <div style="min-width:420px;max-width:420px">
                                                            <strong>Missing dependencies:</strong>
                                                            {% for dep in item.unmetDeps %}
                                                                <div class="mt-1 d-flex align-items-center gap-2">
                                                                    <code style="user-select:all;font-size:0.85em;white-space:nowrap">{{ dep.uuid }}</code>
                                                                </div>
                                                            {% endfor %}
                                                        </div>
                                                    {% endset %}
                                                    <span class="badge bg-warning text-dark ms-1"
                                                        style="cursor:pointer"
                                                        data-bs-toggle="popover"
                                                        data-bs-content="{{ depContent|e('html_attr') }}">
                                                        ⚠️ Missing deps
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if pack.manifest.type.value == 'resources' %}
                                                    Resource 🎨
                                                {% elseif pack.manifest.type.value == 'data' and pack.manifest.hasScriptModule %}
                                                    Behaviour 🔧 📜
                                                {% elseif pack.manifest.type.value == 'data' %}
                                                    Behaviour 🔧
                                                {% else %}
                                                    Behaviour 📜
                                                {% endif %}
                                            </td>
                                            <td><code>{{ pack.manifest.versionString }}</code></td>
                                            <td>
                                                {% if pack.enabled %}
                                                    <span class="badge bg-success status-badge">Enabled</span>
                                                {% else %}
                                                    <span class="badge bg-secondary status-badge">Disabled</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    {% if pack.enabled %}
                                                        <form method="post" action="{{ path('addon_disable', {serverName: server.name, uuid: pack.manifest.uuid}) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger">Disable</button>
                                                        </form>
                                                    {% else %}
                                                        <form method="post" action="{{ path('addon_enable', {serverName: server.name, uuid: pack.manifest.uuid}) }}">
                                                            <button type="submit" class="btn btn-sm btn-outline-success">Enable</button>
                                                        </form>
                                                    {% endif %}
                                                    <button type="button" class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#deleteModal{{ pack.manifest.uuid|replace({'-': ''}) }}">
                                                        🗑
                                                    </button>
                                                </div>

                                                {# Delete confirmation modal #}
                                                <div class="modal fade" id="deleteModal{{ pack.manifest.uuid|replace({'-': ''}) }}" tabindex="-1">
                                                    <div class="modal-dialog modal-sm">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title">Remove add-on</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <p>Are you sure you want to remove <strong>{{ pack.manifest.name }}</strong>? This cannot be undone.</p>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                                                <form method="post" action="{{ path('addon_delete', {serverName: server.name, uuid: pack.manifest.uuid}) }}">
                                                                    <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>

                {% if data.systemPacks is not empty %}
                <div class="card-footer p-0">
                    <details>
                        <summary class="px-3 py-2 text-muted" style="cursor:pointer;list-style:none">
                            ⚙️ <small>{{ data.systemPacks|length }} built-in system pack{{ data.systemPacks|length > 1 ? 's' : '' }} (click to expand)</small>
                        </summary>
                        <div class="table-responsive">
                            <table class="table table-sm table-striped mb-0 text-muted">
                                <thead class="table-secondary">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Version</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for pack in data.systemPacks %}
                                        <tr>
                                            <td>{{ pack.manifest.name }}</td>
                                            <td>
                                                {% if pack.manifest.type.value == 'resources' %}
                                                    Resource 🎨
                                                {% elseif pack.manifest.type.value == 'data' and pack.manifest.hasScriptModule %}
                                                    Behaviour 🔧 📜
                                                {% elseif pack.manifest.type.value == 'data' %}
                                                    Behaviour 🔧
                                                {% else %}
                                                    Behaviour 📜
                                                {% endif %}
                                            </td>
                                            <td><code>{{ pack.manifest.versionString }}</code></td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </details>
                </div>
                {% endif %}

                {% if server.containerId %}
                <div class="card-footer">
                    <form method="post"
                          action="{{ path('server_command', {serverName: server.name}) }}"
                          class="d-flex gap-2"
                          data-command-form="{{ server.name }}">
                        <div class="input-group">
                            <input type="text"
                                   class="form-control form-control-sm font-monospace"
                                   name="command"
                                   id="commandInput{{ server.name }}"
                                   placeholder="e.g. gamerule keepInventory true"
                                   autocomplete="off"
                                   list="commandHistory{{ server.name }}">
                            <datalist id="commandHistory{{ server.name }}"></datalist>
                            <button type="submit" class="btn btn-sm btn-outline-secondary">▶ Send</button>
                        </div>
                    </form>
                </div>
                {% endif %}

            </div>
        {% endfor %}
    {% endif %}


{% endblock %}
