{% extends 'base.html.twig' %}

{% block title %}Dashboard — MC Add-on Manager{% endblock %}

{% block body %}

    {% if serverData is empty %}
        <div class="alert alert-warning">
            No servers found. Make sure your <code>minecraft-data</code> folders are mounted under <code>/mc-data/</code>.
        </div>
    {% else %}
        {% for data in serverData %}
            {% set server = data.server %}
            <div class="card shadow-sm mb-4">
                <div class="card__header card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <h2 class="h5 mb-0">🖥️ {{ server.name }}</h2>
                        {% if server.containerName %}
                            <span class="badge bg-secondary">🐳 {{ server.containerName }}</span>
                        {% endif %}
                        {% if server.port %}
                            <span class="badge bg-secondary">:{{ server.port }}</span>
                        {% endif %}
                        {% if server.isRunning %}
                            <span class="badge bg-success">● Running</span>
                        {% else %}
                            <span class="badge bg-danger">● Stopped</span>
                        {% endif %}
                        <span class="badge bg-success">{{ data.enabledCount }} enabled</span>
                        <span class="badge bg-secondary">{{ data.disabledCount }} disabled</span>
                    </div>
                    <div class="d-flex gap-2">
                        {% if server.containerId %}
                            <form method="post" action="{{ path('server_restart', {serverName: server.name}) }}">
                                <button type="submit" class="btn btn-sm btn-warning">🔄 Restart server</button>
                            </form>
                        {% endif %}
                        <button class="btn btn-sm btn-primary" disabled>⬆️ Install add-on</button>
                    </div>
                </div>

                <div class="card-body p-0">
                    {% if data.packs is empty %}
                        <p class="text-muted p-3 mb-0">No add-ons installed yet.</p>
                    {% else %}
                        <div class="table-responsive">
                            <table class="table table-hover table-striped mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Name</th>
                                        <th>Type</th>
                                        <th>Version</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for pack in data.packs %}
                                        <tr>
                                            <td>{{ pack.manifest.name }}</td>
                                            <td>
                                                {% if pack.manifest.type.value == 'data' %}
                                                    🔧 Behaviour
                                                {% else %}
                                                    🎨 Resource
                                                {% endif %}
                                            </td>
                                            <td><code>{{ pack.manifest.versionString }}</code></td>
                                            <td>
                                                {% if pack.enabled %}
                                                    <span class="badge bg-success">Enabled</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Disabled</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                {% if pack.enabled %}
                                                    <form method="post" action="{{ path('addon_disable', {serverName: server.name, uuid: pack.manifest.uuid}) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">Disable</button>
                                                    </form>
                                                {% else %}
                                                    <form method="post" action="{{ path('addon_enable', {serverName: server.name, uuid: pack.manifest.uuid}) }}">
                                                        <button type="submit" class="btn btn-sm btn-outline-success">Enable</button>
                                                    </form>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    {% endif %}

{% endblock %}
