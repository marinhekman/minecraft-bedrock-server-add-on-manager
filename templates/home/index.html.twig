{% extends 'base.html.twig' %}

{% block title %}{{ app_title|raw }}{% endblock %}

{% block navbar %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<div class="container py-5">

    {# Header #}
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="mb-0">🎮 {{ app_title|raw }}</h1>
        </div>
        <div class="col-auto d-flex align-items-center gap-2">
            <span class="badge bg-light text-dark border d-inline-flex align-items-center gap-1" title="Live: WebSocket status">
                <span data-ws-status-dot style="width:9px;height:9px;border-radius:50%;background:#6c757d;display:inline-block;flex-shrink:0"></span>
                <span>Live</span>
            </span>
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_USER') %}
                <img src="{{ app.user.avatarPath }}"
                     alt="{{ app.user.gamertag }}"
                     class="rounded-circle"
                     style="width:36px;height:36px;object-fit:cover"
                     title="{{ app.user.gamertag }}">
                {% if is_granted('ROLE_ADMIN') %}
                    <span class="badge bg-danger">👑 Admin</span>
                {% else %}
                    <span class="badge bg-success">🎮 User</span>
                {% endif %}
                <span class="text-muted small">{{ app.user.gamertag }}</span>
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" class="btn btn-sm btn-outline-primary">{{ 'Admin Dashboard'|trans }}</a>
                {% endif %}
                <a href="{{ path('logout') }}" class="btn btn-sm btn-outline-secondary">{{ 'Logout'|trans }}</a>
            {% else %}
                <span class="badge bg-secondary">👤 {{ 'Anonymous'|trans }}</span>
                <a href="{{ path('login') }}" class="btn btn-sm btn-primary">{{ 'Login'|trans }}</a>
            {% endif %}
            {# Language switcher #}
            <div class="d-flex gap-1">
                <a href="{{ path('set_locale', {locale: 'nl'}) }}"
                   class="btn btn-sm {{ app.request.locale == 'nl' ? 'btn-secondary' : 'btn-outline-secondary' }}">🇳🇱</a>
                <a href="{{ path('set_locale', {locale: 'en'}) }}"
                   class="btn btn-sm {{ app.request.locale == 'en' ? 'btn-secondary' : 'btn-outline-secondary' }}">🇬🇧</a>
            </div>
        </div>
    </div>

    {# Server cards #}
    {% if serverData is empty %}
        <div class="alert alert-warning">{{ 'No servers found.'|trans }}</div>
    {% else %}
        <div id="server-cards">
        {% for data in serverData %}
            {% set server = data.server %}
            {% set meta   = data.meta %}

            {# Medal for position #}
            {% if loop.index == 1 %}
                {% set medal = '👑' %}
                {% set medalClass = 'text-warning fw-bold' %}
                {% set cardBg = 'card-gold' %}
            {% elseif loop.index == 2 %}
                {% set medal = '🥈' %}
                {% set medalClass = 'text-secondary fw-bold' %}
                {% set cardBg = 'card-silver' %}
            {% elseif loop.index == 3 %}
                {% set medal = '🥉' %}
                {% set medalClass = 'text-danger fw-bold' %}
                {% set cardBg = 'card-bronze' %}
            {% else %}
                {% set medal = '#' ~ loop.index %}
                {% set medalClass = 'text-muted' %}
                {% set cardBg = '' %}
            {% endif %}

            <div class="card shadow-sm mb-4 {{ cardBg }}"
                 data-server="{{ server.name }}"
                 data-vote-count="{{ data.voteCount }}"
                 data-last-started-at="{{ server.startedAt ?? '' }}"
                 data-csrf-token="{{ csrf_token('vote-' ~ server.name) }}">

                {# Card header #}
                <div class="card-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <span class="{{ medalClass }}" title="Position #{{ loop.index }}">{{ medal }}</span>

                        {# Inline-editable display name #}
                        {% if is_granted('ROLE_ADMIN') %}
                            <h2 class="h5 mb-0"
                                data-inline-edit="name"
                                data-server="{{ server.name }}"
                                data-url="/server/{{ server.name }}/meta/name"
                                data-field="display_name"
                                title="{{ 'Click to edit'|trans }}"
                                style="cursor:pointer; border-bottom:1px dashed #aaa">
                                🖥️ {{ meta.getDisplayName(server.name) }}
                            </h2>
                        {% else %}
                            <h2 class="h5 mb-0">🖥️ {{ meta.getDisplayName(server.name) }}</h2>
                        {% endif %}
                        {% set inferredPort = null %}
                        {% if server.name matches '/^server\\d+$/' %}
                            {% set inferredPort = 19131 + ((server.name|replace({'server': ''})) + 0) %}
                        {% endif %}
                        {% set displayPort = server.port ?? inferredPort %}
                        {% if displayPort %}
                            <span class="badge bg-secondary">:{{ displayPort }}</span>
                        {% endif %}
                        {% set awaitingStartup = (not server.isRunning) and (server.containerStatus in ['created', 'restarting', 'starting']) %}
                        {% if server.isRunning %}
                            <span class="badge bg-success server-status-badge">{{ '● Running'|trans }}</span>
                        {% elseif awaitingStartup %}
                            <span class="badge bg-warning text-dark server-status-badge">{{ '⏳ Awaiting startup'|trans }}</span>
                        {% else %}
                            <span class="badge bg-danger server-status-badge">{{ '● Stopped'|trans }}</span>
                        {% endif %}
                        <span class="badge bg-dark stat-uptime" title="{{ 'Uptime'|trans }}"
                              style="{{ server.isRunning ? '' : 'display:none' }}">UP –</span>
                        <span class="badge bg-primary stat-players" title="{{ 'Online players'|trans }}"
                              style="{{ server.isRunning ? '' : 'display:none' }}">👥 –</span>
                    </div>
                </div>

                <div class="card-body">

                    {# Server image and description #}
                    {% if meta.hasImage or meta.description or is_granted('ROLE_ADMIN') %}
                    <div class="d-flex gap-3 mb-3">
                        {# Inline-editable image #}
                        <div style="flex-shrink:0;position:relative" class="server-image-wrapper">
                            {% if meta.hasImage %}
                                <img src="{{ path('server_image', {serverName: server.name}) }}"
                                     alt="{{ meta.getDisplayName(server.name) }}"
                                     class="rounded server-image"
                                     data-server="{{ server.name }}"
                                     style="width:auto;height:120px;object-fit:cover">
                            {% elseif is_granted('ROLE_ADMIN') %}
                                <div class="rounded bg-secondary d-flex align-items-center justify-content-center server-image-placeholder"
                                     data-server="{{ server.name }}"
                                     style="width:120px;height:120px;cursor:pointer;color:#fff;font-size:2rem;"
                                     title="{{ 'Click to upload image'|trans }}">
                                    🖼️
                                </div>
                            {% endif %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <div class="server-image-overlay"
                                     data-server="{{ server.name }}"
                                     data-url="/server/{{ server.name }}/meta/image"
                                     style="position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);display:none;align-items:center;justify-content:center;cursor:pointer;border-radius:0.25rem;color:#fff;font-size:0.85rem;">
                                    {{ '📷 Change'|trans }}
                                </div>
                                <input type="file" class="server-image-input d-none" accept="image/*" data-server="{{ server.name }}" data-url="/server/{{ server.name }}/meta/image">
                            {% endif %}
                        </div>

                        {# Inline-editable description #}
                        <div class="flex-grow-1">
                            {% if is_granted('ROLE_ADMIN') %}
                                <p class="text-muted mb-0"
                                   data-inline-edit="description"
                                   data-server="{{ server.name }}"
                                   data-url="/server/{{ server.name }}/meta/description"
                                   data-field="description"
                                   data-placeholder="{{ 'Click to add a description...'|trans }}"
                                   title="{{ 'Click to edit description'|trans }}"
                                   style="cursor:pointer; min-height:1.5em; border-bottom:1px dashed #aaa">
                                    {{ meta.description ?? 'Click to add a description...'|trans }}
                                </p>
                            {% elseif meta.description %}
                                <p class="text-muted mb-0">{{ meta.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}

                    {# Enabled add-ons #}
                    {% if data.enabledPacks is not empty %}
                        <table class="table table-sm table-hover mb-3">
                            <thead class="table-dark">
                                <tr>
                                    <th>{{ 'Add-on'|trans }}</th>
                                    <th>{{ 'Type'|trans }}</th>
                                    <th>{{ 'Version'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for pack in data.enabledPacks %}
                                    <tr>
                                        <td>{{ pack.manifest.name }}</td>
                                        <td>
                                            {% if pack.manifest.type.value == 'resources' %}
                                                {{ 'Resource 🎨'|trans }}
                                            {% elseif pack.manifest.type.value == 'data' and pack.manifest.hasScriptModule %}
                                                {{ 'Behaviour 🔧 📜'|trans }}
                                            {% elseif pack.manifest.type.value == 'data' %}
                                                {{ 'Behaviour 🔧'|trans }}
                                            {% else %}
                                                {{ 'Behaviour 📜'|trans }}
                                            {% endif %}
                                        </td>
                                        <td><code>{{ pack.manifest.versionString }}</code></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}

                    {# Blocking message — shown when server has votes but can't start #}
                    {% if not server.isRunning and data.voteCount > 0 and data.blocked is not null %}
                        {% if data.blocked == 'players' %}
                            <div class="alert alert-info py-2 mb-3 blocking-block">
                                {{ '👥 Another server has players online. This server will start automatically once they leave.'|trans }}
                            </div>
                        {% elseif data.blocked == 'resources' %}
                            <div class="alert alert-warning py-2 mb-3 blocking-block">
                                {{ '⚠️ Lack of resources — waiting for a server to stop.'|trans }}
                            </div>
                        {% endif %}
                    {% endif %}

                    {# Vote section #}
                    <div class="border-top pt-3 vote-section">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                            {# Left side: avatars + vote count — always visible #}
                            <div class="d-flex align-items-center gap-2">
                                <div class="d-flex vote-avatars">
                                    {% for voter in data.voters|slice(0, 5) %}
                                        <img src="{{ voter.avatarPath }}"
                                             alt="{{ voter.gamertag }}"
                                             title="{{ voter.gamertag }}"
                                             class="rounded-circle border border-white"
                                             style="width:32px;height:32px;object-fit:cover;margin-left:{{ loop.first ? '0' : '-8px' }}">
                                    {% endfor %}
                                    {% if data.voters|length > 5 %}
                                        <span class="badge bg-secondary ms-1 align-self-center">+{{ data.voters|length - 5 }}</span>
                                    {% endif %}
                                </div>
                                <span class="text-muted small vote-count-text">
                                    {{ data.voteCount }} {{ data.voteCount != 1 ? 'votes'|trans : 'vote'|trans }}
                                </span>
                            </div>

                            {# Right side: vote action — always visible #}
                            <div class="vote-action">
                                {% if is_granted('ROLE_USER') or is_granted('ROLE_ADMIN') %}
                                    <form method="post"
                                          action="{{ path('server_vote', {serverName: server.name}) }}"
                                          class="vote-form">
                                        <input type="hidden" name="_token" value="{{ csrf_token('vote-' ~ server.name) }}">
                                        {% if data.userHasVoted %}
                                            <button type="submit" class="btn btn-sm btn-success">
                                                {{ '✓ Voted — click to retract'|trans }}
                                            </button>
                                        {% else %}
                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                {{ 'Vote to start'|trans }}
                                            </button>
                                        {% endif %}
                                    </form>
                                {% else %}
                                    <span class="text-muted small">{{ 'Log in to vote'|trans }}</span>
                                {% endif %}
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        {% endfor %}
        </div>
    {% endif %}

</div>

<script>
    window.myGamertag  = {{ myGamertag ? (myGamertag|json_encode)|raw : 'null' }};
    window.wsUrl       = "{{ ws_scheme }}://{{ ws_host }}:{{ ws_port }}{{ ws_uri }}";
    window.countdownTtl = {{ constant('App\\Service\\RedisClient::COUNTDOWN_TTL') }};
    window.i18n = {
        players:            {{ '👥 Another server has players online. This server will start automatically once they leave.'|trans|json_encode|raw }},
        players_leaving:    {{ '👥 Players have left — waiting for that server to stop before starting this one.'|trans|json_encode|raw }},
        resources:          {{ '⚠️ Lack of resources — waiting for a server to stop.'|trans|json_encode|raw }},
        resources_stopping: {{ '⚠️ Stopping another server to free up resources...'|trans|json_encode|raw }},
        starting_in:        {{ '🚀 Starting in'|trans|json_encode|raw }},
        retract_to_cancel:  {{ 'Retract your vote to cancel'|trans|json_encode|raw }},
        stopping_in:        {{ '🔴 Stopping in'|trans|json_encode|raw }},
        freeing_resources:  {{ 'Freeing resources for voted server'|trans|json_encode|raw }},
        vote_to_start:      {{ 'Vote to start'|trans|json_encode|raw }},
        voted_click_retract:{{ '✓ Voted — click to retract'|trans|json_encode|raw }},
        log_in_to_vote:     {{ 'Log in to vote'|trans|json_encode|raw }},
        running:            {{ '● Running'|trans|json_encode|raw }},
        stopped:            {{ '● Stopped'|trans|json_encode|raw }},
        awaiting_startup:   {{ '⏳ Awaiting startup'|trans|json_encode|raw }},
        starting:           {{ '⏳ Starting...'|trans|json_encode|raw }},
        vote:               {{ 'vote'|trans|json_encode|raw }},
        votes:              {{ 'votes'|trans|json_encode|raw }},
        click_add_description: {{ 'Click to add a description...'|trans|json_encode|raw }},
        image_upload_failed: {{ 'Image upload failed.'|trans|json_encode|raw }},
        image_upload_failed_with_error: {{ 'Image upload failed: %error%'|trans({'%error%': '__ERROR__'})|json_encode|raw }},
        save_failed_with_error: {{ 'Save failed: %error%'|trans({'%error%': '__ERROR__'})|json_encode|raw }},
        unknown_error: {{ 'Unknown error'|trans|json_encode|raw }},
    };

    // ── Inline edit — name and description ────────────────────────────────────
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('[data-inline-edit]').forEach(el => {
            el.addEventListener('click', () => startInlineEdit(el));
        });

        // Image hover overlay
        document.querySelectorAll('.server-image-wrapper').forEach(wrapper => {
            const overlay = wrapper.querySelector('.server-image-overlay');
            const img     = wrapper.querySelector('.server-image, .server-image-placeholder');
            if (!overlay || !img) return;

            wrapper.addEventListener('mouseenter', () => overlay.style.display = 'flex');
            wrapper.addEventListener('mouseleave', () => overlay.style.display = 'none');
            overlay.addEventListener('click', () => {
                const input = wrapper.querySelector('.server-image-input');
                if (input) input.click();
            });
            if (img.classList.contains('server-image-placeholder')) {
                img.addEventListener('click', () => {
                    const input = wrapper.querySelector('.server-image-input');
                    if (input) input.click();
                });
            }
        });

        // Image file input change
        document.querySelectorAll('.server-image-input').forEach(input => {
            input.addEventListener('change', async () => {
                if (!input.files || !input.files[0]) return;
                const url = input.dataset.url;
                const fd  = new FormData();
                fd.append('image', input.files[0]);

                try {
                    const resp = await fetch(url, { method: 'POST', body: fd });
                    const data = await resp.json();
                    if (data.success) {
                        const wrapper = input.closest('.server-image-wrapper');
                        let img = wrapper.querySelector('.server-image');
                        if (!img) {
                            // Replace placeholder with real img
                            const placeholder = wrapper.querySelector('.server-image-placeholder');
                            img = document.createElement('img');
                            img.className = 'rounded server-image';
                            img.style = 'width:auto;height:120px;object-fit:cover';
                            img.alt = '';
                            placeholder.replaceWith(img);
                        }
                        img.src = data.imageUrl;
                    } else {
                        const tpl = window.i18n?.image_upload_failed_with_error || 'Image upload failed: __ERROR__';
                        alert(tpl.replace('__ERROR__', data.error || (window.i18n?.unknown_error || 'Unknown error')));
                    }
                } catch (e) {
                    alert(window.i18n?.image_upload_failed || 'Image upload failed.');
                }

                input.value = '';
            });
        });
    });

    function startInlineEdit(el) {
        const type  = el.dataset.inlineEdit;
        const url   = el.dataset.url;
        const field = el.dataset.field;
        const isName = type === 'name';
        const placeholderText = el.dataset.placeholder || (window.i18n?.click_add_description || 'Click to add a description...');

        const originalText = el.textContent.trim()
            .replace(/^🖥️\s*/, '')
            .replace(new RegExp('^' + placeholderText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '$'), '');

        const input = isName
            ? document.createElement('input')
            : document.createElement('textarea');

        input.value = originalText;
        input.className = 'form-control form-control-sm';
        if (!isName) {
            input.rows = 3;
            input.style.resize = 'vertical';
        }

        el.replaceWith(input);
        input.focus();
        input.select();

        async function save() {
            const newValue = input.value.trim();
            const fd = new FormData();
            fd.append(field, newValue);

            try {
                const resp = await fetch(url, { method: 'POST', body: fd });
                const data = await resp.json();

                if (data.success) {
                    el.textContent = isName ? ('🖥️ ' + (data[field] || newValue)) : (data[field] || newValue || placeholderText);
                } else {
                    el.textContent = isName ? ('🖥️ ' + originalText) : (originalText || placeholderText);
                    const tpl = window.i18n?.save_failed_with_error || 'Save failed: __ERROR__';
                    alert(tpl.replace('__ERROR__', data.error || (window.i18n?.unknown_error || 'Unknown error')));
                }
            } catch (e) {
                el.textContent = isName ? ('🖥️ ' + originalText) : (originalText || placeholderText);
            }

            input.replaceWith(el);
            el.addEventListener('click', () => startInlineEdit(el));
        }

        if (isName) {
            input.addEventListener('keydown', e => {
                if (e.key === 'Enter') { e.preventDefault(); save(); }
                if (e.key === 'Escape') { input.replaceWith(el); el.addEventListener('click', () => startInlineEdit(el)); }
            });
            input.addEventListener('blur', save);
        } else {
            input.addEventListener('keydown', e => {
                if (e.key === 'Enter' && e.ctrlKey) { e.preventDefault(); save(); }
                if (e.key === 'Escape') { input.replaceWith(el); el.addEventListener('click', () => startInlineEdit(el)); }
            });
            input.addEventListener('blur', save);
        }
    }
</script>
{% endblock %}
