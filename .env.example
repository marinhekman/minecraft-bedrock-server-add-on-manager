# ─── Symfony ──────────────────────────────────────────────────────────────────
# Generate a secure secret with: openssl rand -hex 32
APP_SECRET=changeme_use_a_long_random_string

# ─── Caddy / FrankenPHP ───────────────────────────────────────────────────────
# Use SERVER_NAME=:80 to disable HTTPS (e.g. behind a reverse proxy)
SERVER_NAME=localhost
HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443

# ─── Minecraft data folders ───────────────────────────────────────────────────
# Set each variable to the absolute path of a minecraft-data folder on the host.
# The container name (server1, server2, ...) will be used as the display label
# in the UI. Add more entries and uncomment the corresponding volume lines
# in compose.yml to manage additional servers.
MC_DATA_SERVER1=/path/to/your/first/minecraft-data
# MC_DATA_SERVER2=/path/to/your/second/minecraft-data

