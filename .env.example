# ─── Symfony ──────────────────────────────────────────────────────────────────
# Generate a secure secret with: openssl rand -hex 32
APP_SECRET=changeme_use_a_long_random_string

# ─── Caddy / FrankenPHP ───────────────────────────────────────────────────────
# Use SERVER_NAME=:80 to disable HTTPS (e.g. behind a reverse proxy or local use)
SERVER_NAME=:80

HTTP_PORT=80
HTTPS_PORT=443
HTTP3_PORT=443

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://mc-redis:6379

DOCKER_API_URL=http://host.docker.internal:2375
APP_TITLE_RAW=MC&nbsp;Servers

# ─── WebSocket ────────────────────────────────────────────────────────────────
# Dev (default):
URL_WS_SERVER_SCHEME=ws
URL_WEB_SERVER_HOST=host.docker.internal
URL_WS_SERVER_PORT=8082
URL_WS_SERVER_URI=

# Production (behind reverse proxy with wss):
# URL_WS_SERVER_SCHEME=wss
# URL_WEB_SERVER_HOST=mc-servers.example.com
# URL_WS_SERVER_PORT=443
# URL_WS_SERVER_URI=/ws/

# Translation
APP_LOCALE=en
