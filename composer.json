{
    "name": "marinhekman/minecraft-bedrock-addon-manager",
    "description": "Web UI for managing add-ons on itzg/minecraft-bedrock-server instances",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-zip": "*",
        "runtime/frankenphp-symfony": "^0.2",
        "symfony/asset": "^7.4",
        "symfony/asset-mapper": "^7.4",
        "symfony/console": "^7.4",
        "symfony/dotenv": "^7.4",
        "symfony/flex": "^2",
        "symfony/framework-bundle": "^7.4",
        "symfony/http-client": "^7.4",
        "symfony/runtime": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/ux-turbo": "^2.0",
        "symfony/yaml": "^7.4",
        "twig/extra-bundle": "^3.0",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "symfony/debug-bundle": "^7.4",
        "symfony/maker-bundle": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^7.4",
            "docker": true
        }
    }
}
